# Habitica API Credentials
# Get these from: https://habitica.com/user/settings/api
HABITICA_USER_ID=your-user-id-here
HABITICA_API_KEY=your-api-key-here

# Your Habitica Party ID
# Find this in your party URL: https://habitica.com/party/[PARTY_ID]
PARTY_ID=your-party-id-here

# Server Port (Render will provide this automatically)
PORT=3000
